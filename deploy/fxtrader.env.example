# deploy/fxtrader.env.example
# Copy to deploy/fxtrader.env, then edit values for your AWS account/resources.
# Do not put OANDA API keys or AWS secret access keys in this file.

export AWS_PROFILE=fxtrader
export AWS_REGION=us-east-1
export AWS_PAGER=""

export CLUSTER_NAME=fxtrader
export REPO_NAME=fxtrader
export IMAGE_TAG=latest
export SECRET_ID=fxtrader/oanda

# Safe default. Switch with ./deploy/set-mode.sh practice|live
export OANDA_ENV=practice
export ENABLE_LIVE_TRADING=false

# EventBridge schedule settings.
export SCHEDULE_NAME=fxtrader-m-f-0258-ny
export SCHEDULE_TIMEZONE=America/New_York
export SCHEDULE_CRON='cron(58 2 ? * MON-FRI *)'

# Fill these in after creating networking/roles, or let deploy/load-env.sh derive what it can.
# export VPC_ID="vpc-..."
# export SUBNET_IDS="subnet-...,subnet-..."
# export SECURITY_GROUP_ID="sg-..."
# export TASK_EXECUTION_ROLE_ARN="arn:aws:iam::...:role/ecsTaskExecutionRole"
# export SCHEDULER_ROLE_ARN="arn:aws:iam::...:role/fxtrader-eventbridge-scheduler-role"
